#!/usr/bin/env bash
set -euo pipefail

instance=${1:?Usage: scripts/create INSTANCE}
[[ "$instance" =~ ^[a-z0-9][a-z0-9-]{0,30}$ ]] || { echo 'Invalid instance name' >&2; exit 2; }
repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
runtime="$repo_root/.runtime/$instance"
umask 077
mkdir -p "$runtime"
: > "$runtime/known_hosts"

limactl start --name="$instance" "$repo_root/lima/dev.yaml"
printf 'Created %s. Run scripts/provision %s when roles are implemented.\n' "$instance" "$instance"
